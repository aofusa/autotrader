{
    "bitflyer": {
        "label": "{{ your_key_label }}",
        "key": "{{ your_key }}",
        "secret": "{{ your_secret }}",
        "candle-interval": "4h",
        "spot-reserves": {
            "ETH": 0.0
        },
        "endpoint": {
            "url": "https://api.bitflyer.com"
        }
    },
    "trading": {
        "products": "btc",
        "available-products": [
            "btc",
            "eth",
            "both"
        ],
        "strategy": {
            "fast-span": 20,
            "slow-span": 300,
            "donchian-span": 200,
            "atr-span": 14,
            "trail-atr-mult": 4.0,
            "allow-short": true
        },
        "risk": {
            "max-leverage": 2.0,
            "risk-per-trade": 0.06,
            "margin-usage-limit": 0.7,
            "drawdown-soft": 0.1,
            "drawdown-hard": 0.35,
            "drawdown-min-scale": 0.25
        },
        "rebalance-threshold": 0.3,
        "paper": {
            "initial-jpy": 500000,
            "candle-interval": "4h",
            "slippage": 0.0005,
            "swap-rate-daily": 0.0004,
            "spot-fee-rate": 0.0015,
            "state-path": "docs/artifacts/paper_state.json"
        }
    }
}